rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /Users/{userId} {
      allow read, write: if true;
    }
    match /players/{playerId} {
      allow read: if true;
    }
    match /teams/{teamId} {
      allow read, write: if true;
    }
    match /leagues/{leagueId}/matches/{matchId} {
      allow read: if true;
    }
  }
}
